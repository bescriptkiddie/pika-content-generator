# LLM Configuration (for M2 analyze + M3 generate)
# 默认使用智谱 GLM-5.1 (通过 Anthropic 兼容接口)
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://open.bigmodel.cn/api/anthropic
LLM_MODEL=glm-5.1

# GEOFlow API (for M4 GEO execute)
GEOFLOW_API_TOKEN=

# Xiaohongshu browser provider
XHS_BROWSER_BACKEND=playwright_persistent
XHS_PLAYWRIGHT_USER_DATA_DIR=~/.pikaengine/playwright/xiaohongshu
XHS_PLAYWRIGHT_HEADLESS=false
XHS_PLAYWRIGHT_CHANNEL=chrome
XHS_BROWSER_STARTUP_TIMEOUT=30000
XHS_BROWSER_ACTION_TIMEOUT=15000
XHS_BROWSER_NAVIGATION_TIMEOUT=30000
XHS_BROWSER_REQUEST_TIMEOUT=20

# Optional legacy CDP HTTP backend
CDP_BASE=http://localhost:3456

# Optional hosted trending provider
DAILYHOT_API_BASE=http://localhost:6688

# Optional local xhs-cli source checkout
# 留空时要求 xhs-cli 已安装到当前 Python 环境
XHS_CLI_MODULE_PATH=
